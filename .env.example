OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_API_MODEL=gpt-5.4

# Common OpenAI-compatible base URLs:
# OpenAI
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# Anthropic OpenAI SDK compatibility
# OPENAI_API_BASE_URL=https://api.anthropic.com/v1/
# Gemini OpenAI compatibility
# OPENAI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Ollama at e-INFRA CZ
# OPENAI_API_BASE_URL=https://llm.ai.e-infra.cz/v1

FACTICLI_SEARCH_PROVIDER=openai
# Only needed when FACTICLI_SEARCH_PROVIDER=brave:
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Optional web GUI (pip install -e ".[web]"; python -m facticli.web)
# FACTICLI_WEB_HOST=127.0.0.1
# FACTICLI_WEB_PORT=8000
